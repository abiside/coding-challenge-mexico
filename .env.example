APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=18080
WWWUSER=1000
WWWGROUP=1000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Market data feed (conectores WebSocket de exchanges)
# Incluimos ETH/BTC para habilitar ciclos triangulares intra-exchange
# (USDT -> BTC -> ETH -> USDT) sin necesidad de transferencias entre wallets.
MARKET_FEED_EXCHANGES=binance,kraken,coinbase,bybit,okx,bitget,bybit,okx,bitget
MARKET_FEED_STREAMS=ticker,orderbook
MARKET_FEED_SYMBOLS=BTC/USDT,ETH/USDT,ETH/BTC
MARKET_FEED_SYMBOLS_KRAKEN=BTC/USD,ETH/USD,ETH/BTC
MARKET_FEED_SYMBOLS_COINBASE=BTC/USD,ETH/USD,ETH/BTC
MARKET_FEED_SYMBOLS_BYBIT=BTC/USDT,ETH/USDT,ETH/BTC
MARKET_FEED_SYMBOLS_OKX=BTC/USDT,ETH/USDT,ETH/BTC
MARKET_FEED_SYMBOLS_BITGET=BTC/USDT,ETH/USDT,ETH/BTC
MARKET_FEED_REDIS_CONNECTION=default
MARKET_FEED_CHANNEL_PREFIX=market
MARKET_FEED_LATEST_TTL=300
MARKET_FEED_BACKOFF_BASE_MS=1000
MARKET_FEED_BACKOFF_CAP_MS=30000
MARKET_FEED_STATUS_INTERVAL=30
MARKET_FEED_LOG_MESSAGES=false

REVERB_APP_ID=123456
REVERB_APP_KEY=local-app-key
REVERB_APP_SECRET=local-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Engine de arbitraje (app/Arbitrage + comando arbitrage:run)
ARBITRAGE_SYMBOLS=BTC/USDT,ETH/USDT,ETH/BTC
ARBITRAGE_FRESHNESS_MS=2000
# Logs debug por cada comparativa de books (por qué se descarta cada cruce). Apagar en prod.
ARBITRAGE_DIAGNOSTICS=false
ARBITRAGE_MIN_NET_PROFIT=1.0
ARBITRAGE_MIN_NET_MARGIN=0.0005
ARBITRAGE_MIN_BASE_VOLUME=0.0001
ARBITRAGE_MAX_BASE_VOLUME=1.0
ARBITRAGE_LATENCY_MAX_MS=1500
ARBITRAGE_CB_ENABLED=true
ARBITRAGE_PERSISTENCE_ENABLED=true
ARBITRAGE_DASHBOARD_ENABLED=true
ARBITRAGE_DASHBOARD_CHANNEL=arbitrage-dashboard
ARBITRAGE_EVAL_INTERVAL=60

# Arbitraje triangular (ciclos multi-pata)
# Detecta ciclos cerrados USDT -> BTC -> ETH -> USDT (intra-exchange) o
# cross-exchange con equivalencias de inventario. Comparte store/wallets con
# el engine de 2 patas y reutiliza fees/guards/risk manager. Ver:
# app/Arbitrage/Triangular y docs/triangular_arbitrage.md.
ARBITRAGE_TRIANGULAR_ENABLED=false
ARBITRAGE_TRIANGULAR_MAX_LENGTH=3
ARBITRAGE_TRIANGULAR_CROSS_EXCHANGE=true
ARBITRAGE_TRIANGULAR_TRANSFER_COST=0.0
ARBITRAGE_TRIANGULAR_START_ASSETS=USDT,USD
ARBITRAGE_TRIANGULAR_MIN_NET_PROFIT=1.0
ARBITRAGE_TRIANGULAR_MIN_NET_MARGIN=0.0005
ARBITRAGE_TRIANGULAR_MIN_START=10.0
ARBITRAGE_TRIANGULAR_MAX_START=10000.0

# Autopilot AI (opcional). Sin AI_API_KEY el autopilot funciona como
# optimizador estadístico puro; el LLM solo añade validación y rationale.
AI_AUTOPILOT_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_TIMEOUT_SECONDS=20
AI_FALLBACK_TO_OPTIMIZER=true
